{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node",
      "react"
    ],
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "references": [
    {
      "path": "../contracts"
    },
    {
      "path": "../shared-utils"
    },
    {
      "path": "../ai-runtime-layer"
    },
    {
      "path": "../control-plane-layer"
    }
  ],
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}

