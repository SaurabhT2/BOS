{
  "name": "@brandos/presentation-layer",
  "version": "1.0.0",
  "description": "UI components, renderers, shells, and auth surface — no business logic",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run __tests__/contract",
    "test:unit": "vitest run __tests__/unit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@brandos/contracts": "workspace:*",
    "@brandos/shared-utils": "workspace:*",
    "lucide-react": "0.468.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/browser": "^2.1.0",
    "jsdom": "^29.1.1",
    "rimraf": "^5.0.0",
    "typescript": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}

