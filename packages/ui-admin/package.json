{
  "name": "@brandos/ui-admin",
  "version": "1.0.0",
  "description": "Shared admin UI primitives — no more copy-paste across pages",

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },

  "files": ["dist"],

  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },

  "dependencies": {
    "react": "^19.0.0"
  },

  "peerDependencies": {
    "react": "^19.0.0"
  },

  "devDependencies": {
    "typescript": "^6.0.0",
    "@types/react": "^18.0.0",
    "vitest": "^2.0.0",
    "rimraf": "^5.0.0"
  }
}


