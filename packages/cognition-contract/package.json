{
  "name": "@platform/cognition-contract",
  "version": "1.0.0",
  "description": "Zero-dependency cross-platform system contract between BrandOS (Execution Platform) and IntelligenceOS (Cognitive Platform). Types only — no runtime logic.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
