{
  "name": "@brandos/iskill-runtime",
  "version": "1.0.0",
  "description": "Governed capability runtime for BrandOS ISkills and ICP Bundles",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@brandos/contracts": "workspace:*",
    "@brandos/governance-config": "workspace:*",
    "@brandos/shared-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^6.0.0",
    "vitest": "^1.6.0",
    "rimraf": "^5.0.0"
  }
}


