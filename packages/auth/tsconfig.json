{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],

    "types": ["node"]
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__/**/*",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}

