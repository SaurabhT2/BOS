{
  "name": "@brandos/governance-layer",
  "version": "2.0.0",
  "description": "Semantic governance authority — artifact validation, scoring, repair, and integrity checks",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:contract": "vitest run __tests__/contract",
    "test:boundary": "vitest run __tests__/boundary",
    "test:regression": "vitest run __tests__/regression",
    "validate": "node -e \"require('./dist/validatePackage.js').validatePackage().then(r => { console.log(JSON.stringify(r, null, 2)); if (!r.healthy) process.exit(1); })\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@brandos/contracts": "workspace:*",
    "@brandos/governance-config": "workspace:*",
    "@brandos/shared-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "rimraf": "^5.0.0"
  }
}


