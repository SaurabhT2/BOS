{
  "name": "@brandos/governance-config",
  "version": "1.0.0",
  "description": "Single source of truth for governance and policy configuration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
