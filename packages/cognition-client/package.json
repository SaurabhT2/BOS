{
  "name": "@brandos/cognition-client",
  "version": "1.0.0",
  "description": "The single adapter boundary between BrandOS and IntelligenceOS. Only package permitted to hold a concrete CognitionProvider implementation.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@platform/cognition-contract": "workspace:*",
    "@brandos/shared-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
