{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node"]
  },
  "references": [
    { "path": "../contracts" },
    { "path": "../output-control-layer" },
    { "path": "../governance-layer" },
    { "path": "../iskill-runtime" }
  ],
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "src/tests/**/*",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}

