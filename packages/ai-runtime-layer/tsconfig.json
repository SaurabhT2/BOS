{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node"]
  },
  "references": [
    { "path": "../contracts" },
    { "path": "../shared-utils" }
  ],
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__/**",
    "src/__tests_disabled/**",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}

